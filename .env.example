# ZugaMind environment variables — every knob the package reads, with its
# default. Nothing here is required: a fresh clone runs with zero env setup.
# Copy to .env and source it (or export vars directly) to override.

# --- Model access (only needed for real, non-dry-run wakes) -------------------
# ANTHROPIC_API_KEY=            # paid tiers (haiku/sonnet/opus) via the action gate
# OLLAMA_URL=http://localhost:11434   # local free tier endpoint
# ZUGAMIND_LOCAL_MODEL=qwen2.5:14b-instruct

# --- Paths --------------------------------------------------------------------
# ZUGAMIND_DATA_DIR=            # relocate ALL runtime state (engine files,
                                # scanner caches, value DB); default zugamind/data/

# --- Budget (hard monthly cap for paid-tier calls) -----------------------------
# ZUGAMIND_MONTHLY_BUDGET_USD=10.00
# ZUGAMIND_HAIKU_COST=0.005     # per-call cost heuristics for the local ledger
# ZUGAMIND_SONNET_COST=0.05
# ZUGAMIND_OPUS_COST=0.50

# --- Runner / cycle ------------------------------------------------------------
# ZUGAMIND_POLL_INTERVAL=180    # seconds between daemon cycles
# ZUGAMIND_SENTINEL_TIMEOUT=90
# ZUGAMIND_REASONING_TIMEOUT=180
# ZUGAMIND_HABITUATION_HOURS=6  # a seen trigger is damped for this many hours
# ZUGAMIND_BRIEFING_MAX_CHARS=4000

# --- Harness wake path ----------------------------------------------------------
# ZUGAMIND_HARNESS_CONFIG=      # path to harness config JSON; default zugamind/data/harness.json
# ZUGAMIND_QUIET_HOURS=         # "HH:MM-HH:MM" — suppress wakes (perception continues)

# --- Scanners -------------------------------------------------------------------
# ZUGAMIND_WATCH_REPOS=         # comma-separated "owner/repo" list for the GitHub issues scanner
# GITHUB_TOKEN=                 # optional: raises the GitHub API rate limit
# ZUGAMIND_HN_TOP_TTL=300       # HackerNews cache TTLs (seconds)
# ZUGAMIND_HN_ITEM_TTL=3600
# ZUGAMIND_SOURCE_SCHEDULER_ENABLED=   # opt-in cadence gating + yield budget
# ZUGAMIND_PER_SCANNER_CAP=3
# ZUGAMIND_GLOBAL_TRIGGER_CEILING=40

# --- Value gate (post-hoc usefulness scoring; ships dark) ------------------------
# ZUGAMIND_VALUE_GATE_ENABLED=false
# ZUGAMIND_VALUE_WINDOW=50
# ZUGAMIND_VALUE_DAMPEN_BELOW=0.3
# ZUGAMIND_VALUE_FLOOR=0.1
# ZUGAMIND_VALUE_BOOST=1.1
# ZUGAMIND_VALUE_BOOST_ABOVE=0.7
# ZUGAMIND_VALUE_MIN_SAMPLES=5
# ZUGAMIND_REPO_ROOT=           # fallback root for the value DB if foundation is unavailable

# --- Misc ------------------------------------------------------------------------
# ZUGAMIND_COGNITION_MOD_AUDIT= # audit-log path for the self-mod cooldown gate
